#!/bin/bash
# Pre-commit hook: run `make lint` when the commit touches Go source.
#
# Scoped to lint — not the full `make check`, which also runs the multi-minute
# coverage + persistence suite — so it stays affordable on every commit. And
# gated on staged Go files (incl. go.mod/go.sum) so the constant
# memory/stewardship/cron auto-commits, which touch only markdown/config, skip
# it entirely and aren't blocked by an unrelated lint state.
#
# Activate with `make setup-hooks` (sets core.hooksPath to .githooks).
set -e

# Names staged in this commit (includes deletions: removing a .go file can
# create new deadcode / disconnected-test failures that lint must catch).
staged_go=$(git diff --cached --name-only | grep -E '\.go$|^go\.(mod|sum)$' || true)

if [ -z "$staged_go" ]; then
	exit 0
fi

echo "Running pre-commit lint (staged Go changes detected)..."
make lint
echo "✅ pre-commit lint passed"

# Nudge only (never blocks) — but the CHECK it prompts is mandatory, not optional.
# docs/WIRING.md is the connection map: "How the pieces connect. Read this before
# touching the code." ANY wiring change — a new/renamed/removed callback, flow,
# package, or timer, OR a new call site added to a list the doc enumerates — requires
# opening WIRING.md to verify whether an update or addition is needed. Staged Go
# changes with no WIRING.md touch is the signal to do that check; leaving it untouched
# is correct ONLY after you've opened it and confirmed nothing it documents changed.
#
# Fires UNLESS every staged file is a test or a doc — a denylist, not an allowlist of
# code extensions (which would miss shell scripts and other languages that also rewire
# things). Excludes Go test files (*_test.go) and Markdown docs (*.md); anything else —
# Go, shell, other code, config — counts as a possible wiring change and fires. Errs
# toward over-nudging, since a missed wiring change is the costly case. Deletions count
# too (removing a callback/package is a wiring change).
staged_code=$(git diff --cached --name-only | grep -Ev '(_test\.go|\.md)$')
if [ -f docs/WIRING.md ] && [ -n "$staged_code" ] && ! git diff --cached --name-only | grep -qx 'docs/WIRING.md'; then
	echo "⚠️  docs/WIRING.md ('How the pieces connect') wasn't touched by this commit."
	echo "    Do NOT ignore this: ANY wiring change — new/renamed/removed callback, flow,"
	echo "    package, timer, or a call site added to a list the doc enumerates — requires"
	echo "    CHECKING WIRING.md to verify whether an update or addition is required."
	echo "    Skip the update only after opening it and confirming nothing it maps changed;"
	echo "    if it does, update WIRING.md and amend this commit."
fi
