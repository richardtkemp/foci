# Foci Secrets — keep this file restricted (chmod 660, owned by root:foci-secrets)
#
# Place in the same directory as foci.toml. Values here override matching
# fields in foci.toml. setup.sh handles permissions automatically.

# ─── Anthropic Authentication ─────────────────────────────────────────
# Option 1: OAuth (recommended for Max/Pro plans). Run `foci auth` to populate.
# [anthropic]
# oauth_access_token = "sk-ant-oat01-..."
# oauth_refresh_token = "sk-ant-ort01-..."
# oauth_expires_at = 1772334580401

# Option 2: Setup token (from `claude setup-token` or Anthropic console)
# [anthropic]
# setup_token = "sk-ant-..."

# ─── Telegram Bot Tokens ──────────────────────────────────────────────
# One section per bot. The key must match the agent ID or bot name in foci.toml.
[telegram.bots.myagent]
token = "123456789:AAF-YOUR_BOT_TOKEN_HERE"

# ─── Optional: Additional Secrets ─────────────────────────────────────
# Available as {{secret:NAME}} in http_request headers/body.
# Dot-separated keys become nested TOML sections.
#
# [brave]
# api_key = "BSA..."            # Brave Search API (for web_search tool)
#
# [openrouter]
# api_key = "sk-or-..."         # OpenRouter (for image-gen, research skills)
#
# [voice]
# api_key = "..."               # Voice WebSocket authentication
