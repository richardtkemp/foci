# Foci Configuration Reference
#
# Exhaustive reference of every configuration option.
# Secrets (API keys, tokens) go in secrets.toml — see secrets.toml.example.

# ─── Top-level ────────────────────────────────────────────────────────
# data_dir = "/home/foci/data"            # directory for databases, sessions, state (default: $HOME/data)
# welcome_file = "WELCOME.md"             # changelog/welcome file injected on startup
# skip_security_checks = false            # skip startup security checks for secrets.toml

# ─── Groups ──────────────────────────────────────────────────────────
# Model groups control which model is used for each type of LLM call.
# "powerful" is the primary model (chat, compaction, memory). Required.
# "fast" and "cheap" default to powerful when unset.
# Values are model names defined in [models.*] or developer/model_id strings.
[groups]
powerful = "haiku"
# fast = "haiku"
# cheap = "haiku"

# ─── Models ──────────────────────────────────────────────────────────
# Named model definitions with per-model settings.
# Each [models.<name>] section defines a model and its parameters.
[models.haiku]
model = "anthropic/claude-haiku-4-5-20251001"
# thinking = "adaptive"                  # adaptive (default for anthropic), off
# effort = "low"                         # low, medium, high
# speed = ""                             # fast or empty (Opus only, 6x pricing)
# enable_keepalive                       # omit for auto-detect, true/false for explicit
# prompt_cache_ttl = ""                  # Go duration, empty=auto-detect

# ─── Agent Loop ──────────────────────────────────────────────────────
# Settings consumed by the agent loop (HandleTurn). Per-agent: [[agents]].agent_loop.*
# [agent_loop]
# max_tool_loops = 25
# max_output_tokens = 16384
# duplicate_messages = false              # send user text twice per API call
# batch_partial_assistant_messages = false # accumulate mid-turn text; send on turn end
# batch_partial_joiner = ""               # separator between batched partial messages
# cache_ttl = ""                          # per-agent Anthropic cache TTL override ("5m" or "1h")

# ─── Behavior ───────────────────────────────────────────────────────
# Agent behavioral settings. Per-agent: [[agents]].behavior.*
# [behavior]
# steer_mode = true                       # inject user messages between tool calls (default true)
# group_throttle = ""                     # group chat throttle window (e.g. "30s", "0" disables)
# turn_lock_warn_threshold = "3m"         # warn if turn lock wait exceeds this duration
# enable_stop_aliases = true              # enable stop command aliases
# stop_aliases = ["stop", "wait"]         # aliases for /stop command

# ─── Notify ─────────────────────────────────────────────────────────
# Notification settings. Per-agent: [[agents]].notify.*
# [notify]
# startup_notify = true
# compaction_notify = true
# task_list_notify = true

# ─── Display ────────────────────────────────────────────────────────
# Display defaults (also settable per-platform in [[platforms]]). Per-agent: [[agents]].display.*
# [display]
# streaming = false                        # use streaming API (per-agent override)
# injected_message_header = "[[ System message ]]"  # header for system messages (empty disables)

# ─── Voice ──────────────────────────────────────────────────────────
# TTS/STT settings. Per-agent: [[agents]].voice.*
# [voice]
# tts = ""                                # override TTS entry by id (empty = default)
# stt = ""                                # override STT entry by id (empty = default)
# tts_rate = 0.0                          # speech rate multiplier (0 = use entry rate)

# ─── Nudge ──────────────────────────────────────────────────────────
# Nudge system settings. Per-agent: [[agents]].nudge.*
# [nudge]
# nudge_default_braindead_threshold = 10               # consecutive tool loops before warning (0 = disabled)
# nudge_default_braindead_prompt = ""                   # warning text injected at threshold

# ─── System ─────────────────────────────────────────────────────────
# System-level agent settings. Per-agent: [[agents]].system.*
# [system]
# system_files = ["character/SOUL.md"]    # default system file list
# webhooks = { deploy = "deploy.md", alert = "alert.md" }  # webhook hook ID → prompt path

# ─── More model examples ─────────────────────────────────────────────
# [models.opus]
# model = "anthropic/claude-opus-4-6"
# thinking = "adaptive"
# effort = "low"
#
# [models.sonnet]
# model = "anthropic/claude-sonnet-4-6"
# thinking = "adaptive"
#
# [models.gemini-flash]
# model = "google/gemini-2.5-flash"
# thinking = "adaptive"
#
# [models.deepseek]
# model = "deepseek/deepseek-chat"
# enable_keepalive auto-detected (DeepSeek developer → 5m cache TTL)

# ─── Agent ────────────────────────────────────────────────────────────
# Define one or more agents. Each gets its own sessions, memory, and bot.
#
# Platform configuration:
#   [[agents.platforms]]
#   id = "telegram"
#   bot = "myagent"               # bot name; token via "telegram.<bot>" secret
#   bot_secret = "custom.key"     # override secret key (default: "telegram.<bot>")
#   facet_bots = ["bot2", "bot3"]  # additional bots for facet
#   [agents.platforms.access]
#   allowed_users = ["12345"]     # per-agent Telegram user filter
#   [agents.platforms.display]
#   show_tool_calls = "preview"   # off, preview, full
#   show_thinking = "off"         # off, compact, true
#   display_width = 44
#   stream_output = false
#   stream_interval = "250ms"
#   received_files_dir = "received"
#
#   [[agents.platforms]]
#   id = "discord"
#   bot = "myagent"               # bot name; token via "discord.<bot>" secret
#   bot_secret = "custom.key"     # override secret key (default: "discord.<bot>")
#   [agents.platforms.access]
#   allowed_users = ["12345"]     # per-agent Discord user filter
#   require_mention = true        # require @mention in guild channels
#   [agents.platforms.display]
#   show_tool_calls = "off"       # off, preview, full
#   show_thinking = "off"         # off, compact, true
#   display_width = 60
#   stream_output = false
#   stream_interval = "1200ms"
#   received_files_dir = "received"
#   [agents.platforms.discord]    # discord-specific fields
#   guild_id = ""                 # restrict to this guild (empty = all)
#   auto_thread = true            # create threads for facet sessions

[[agents]]
id = "myagent"
# name = "My Agent"                       # human-readable name (default: capitalised id)
# emoji = "🤖"
# workspace = "/home/foci/myagent"        # working directory (default: $HOME/id)
# skills_dir = "skills"                   # per-agent skills directory (default: $workspace/skills/)

# Per-agent section overrides (each prefix matches its global TOML section):
# [agents.agent_loop]
# max_tool_loops = 25
# max_output_tokens = 16384
# duplicate_messages = false
# [agents.behavior]
# turn_lock_warn_threshold = "3m"
# [agents.nudge]
# nudge_default_braindead_threshold = 10
# nudge_default_braindead_prompt = ""
# [agents.notify]
# startup_notify = true                   # send startup notification (nil = use global)
# [agents.display]
# streaming = false                        # per-agent streaming override
# [agents.voice]
# tts_rate = 0.0
[agents.system]
system_files = [
  "character/SOUL.md",
  "character/CRAFT.md",
]
# webhooks = {}
# [agents.debug]
# messages_in_log = false                 # log user message content (privacy)
# inject_agent_warnings = "off"           # "all", "errors", "off"
# inject_chat_warnings = "off"            # "all", "errors", "off"

# Per-agent session overrides:
# [agents.sessions]
# branch_orientation_facet_prompt = "prompts/orient-facet.md"  # prompt for user-attached facet branches
# branch_orientation_headless_prompt = "prompts/orient-headless.md"   # prompt for headless branches (cron, spawn, keepalive)
# compaction_effort = "high"              # effort for compaction API calls

# Per-agent tool overrides:
# [agents.tools]
# exec_auto_background = 10              # seconds before auto-backgrounding exec
# max_concurrent_spawns = 3
# explore_max_depth = 100                # max tool loops for explore spawn mode
# max_upload_file_size = 52428800         # 50MB
# tmux_autopilot = true
# tmux_watch_threshold = "30s"
# tmux_session_ttl = "24h"               # auto-kill idle tmux sessions ("0" disables)
# max_result_chars = 15000               # override [tools] value
# max_summary_chars = 300000             # override [tools] value
# auto_summarise = true                  # override [tools] value
# summary_context_turns = 5
# summary_context_chars = 6000

# ─── Agent: Platform overrides ───────────────────────────────────────
# Per-agent platform settings override global [[platforms]] entries.
#
# [[agents.platforms]]
# id = "telegram"
# bot = "myagent"                         # bot name (token from "telegram.myagent" secret)
# bot_secret = ""                         # override secret key
# facet_bots = []                         # additional bot names for facet
# [agents.platforms.access]
# allowed_users = []                      # per-agent allowed users (empty = use global)
# [agents.platforms.display]
# show_tool_calls = "preview"             # off, preview, full
# show_thinking = "off"                   # off, compact, true
# display_width = 44
# stream_output = false
# stream_interval = "250ms"
# received_files_dir = ""
# [agents.platforms.telegram]
# table_wrap_lines = 5
# table_style = "pretty"

# Per-agent compaction overrides:
# compaction_threshold = 0.8
# compaction_summary_prompt = "prompts/compaction-summary.md"
# compaction_handoff_msg = ""
# compaction_preserve_messages = 25
# [agents.notify]
# compaction_notify = true
# [agents.debug]
# compaction_debug = false                 # per-agent override; global moved to [debug]

# Per-agent blocked paths (replaces global):
# [[agents.blocked_paths]]
# path = "/home/foci/myagent/code"
# rebuke = "Use claude via tmux for code changes."

# Per-agent message transforms:
# [[agents.message_transforms]]
# find = "pattern"
# replace = "replacement"

# Per-agent memory sources:
# [[agents.memory.sources]]
# name = "docs"
# dir = "memory/docs"
# weight = 0.8

# Per-agent usage warnings:
# [agents.usage_warnings]
# thresholds = [50, 25, 10, 5]
# restore_threshold = 40                  # override global restore_threshold

# Per-agent background task scheduling:
# [agents.background]
# enabled = true
# interval = "5m"                         # time since last interaction before firing
# prompt = "Check your todo list."

# Per-agent keepalive (cache warming):
# [agents.keepalive]
# enabled = true
# interval = "55m"
# prompt = ""                             # empty = embedded default, "none" = disabled

# Per-agent memory formation:
# [agents.memory_formation]
# interval_enabled = true
# interval = "1h"
# interval_prompt = ""
# consolidation_enabled = true
# consolidation_interval = "20h"
# consolidation_prompt = ""
# session_end_enabled = true
# session_end_prompt = ""

# ─── Anthropic ────────────────────────────────────────────────────────
# API keys go in secrets.toml. These are non-secret settings only.
# Model params (thinking, effort, speed) are now per-model in [models.*].
[anthropic]
# http_timeout = "600s"                   # HTTP timeout for API calls
# usage_api_timeout = "10s"              # HTTP timeout for usage API
# usage_cache_ttl = "10m"                # cache TTL for usage API responses
# cc_expiry_threshold = "5m"            # how far before expiry to trigger proactive token refresh
# use_sdk = true                         # use SDK transport (false = raw HTTP fallback)
# streaming = false                      # use streaming API (requires use_sdk)

# ─── Gemini ────────────────────────────────────────────────────────────
# API keys go in secrets.toml as gemini.api_key.
# Model params (thinking) are now per-model in [models.*].
[gemini]
# http_timeout = "120s"                   # HTTP timeout for API calls
# cache_ttl = "1h"                        # context cache TTL ("0" disables)

# ─── OpenAI ────────────────────────────────────────────────────────────
# API keys go in secrets.toml as openai.api_key.
# Also works with OpenAI-compatible endpoints (OpenRouter, Together, Groq, etc.)
# Model params (reasoning/thinking) are now per-model in [models.*].
[openai]
# base_url = ""                           # API base URL (empty = sdk default; override for OpenRouter etc.)
# http_timeout = "120s"                   # HTTP timeout for API calls

# ─── Platforms ────────────────────────────────────────────────────────
# Platforms are configured as [[platforms]] array entries. Each entry has
# an id ("telegram", "discord") and platform-specific settings.
# Per-agent overrides use [[agents.platforms]] with the same structure.

[[platforms]]
id = "telegram"
# facet_bots = ["bot2", "bot3"]       # shared facet bot pool
# facet_session_ttl = "60m"           # idle TTL before bot reclaim ("0" disables)
# message_queue_size = 64
[platforms.access]
allowed_users = ["YOUR_TELEGRAM_USER_ID"]
# require_mention = true              # require @mention in group chats
# [platforms.notify]
# startup_notify = true
# [platforms.display]
# show_tool_calls = "off"             # off, preview, full
# show_thinking = "off"               # off, compact, true
# stream_output = false
# stream_interval = "250ms"
# display_width = 44
# received_files_dir = ""             # save received files (per-agent overrides)
# [platforms.telegram]                # telegram-specific settings
# long_poll_timeout = "65s"
# table_wrap_lines = 5
# table_style = "pretty"             # "pretty" or "markdown"

# [[platforms]]
# id = "discord"
# facet_session_ttl = "60m"            # idle TTL before thread reclaim
# message_queue_size = 64
# [platforms.access]
# allowed_users = ["YOUR_DISCORD_USER_ID"]
# require_mention = true               # require @mention in guild channels
# [platforms.notify]
# startup_notify = true
# [platforms.display]
# show_tool_calls = "off"              # off, preview, full
# show_thinking = "off"                # off, compact, true
# stream_output = false
# stream_interval = "1200ms"
# display_width = 60
# received_files_dir = ""              # save received files (per-agent overrides)
# [platforms.discord]                  # discord-specific settings
# auto_thread = true                   # create threads for facet sessions
# guild_id = ""                        # restrict to a single guild (empty = all)

# ─── Sessions ─────────────────────────────────────────────────────────
[sessions]
# dir = "/home/foci/data/sessions"
compaction_threshold = 0.8
# compaction_max_tokens = 4096
# compaction_min_messages = 4
# compaction_summary_prompt = "prompts/compaction-summary.md"
# compaction_handoff_msg = ""
# compaction_preserve_messages = 25
# max_system_prompt_chars_file = 20000
# max_system_prompt_chars_total = 80000
# branch_orientation_prompt = ""                                  # deprecated: sets both facet and headless
# branch_orientation_facet_prompt = ""                        # prompt for user-attached facet branches
# branch_orientation_headless_prompt = ""                         # prompt for headless branches (cron, spawn, keepalive)
# archive_after = "24h"                   # gzip idle sessions after 24 hours

# ─── Skills ───────────────────────────────────────────────────────────
# [skills]
# dir = "/home/foci/shared/skills"       # shared skills directory (default: $home/shared/skills/)

# ─── Memory ───────────────────────────────────────────────────────────
# [memory]
# search_backends = ["bleve"]              # active backends: "fts5", "bleve", or both
# reindex_debounce = "0s"
# conversation_weight = 0.1
# search_limit = 20
# sweep_interval = "1h"                   # periodic full reindex ("0" disables)

# [[memory.sources]]
# name = "shared"
# dir = "/home/foci/shared/memory"
# weight = 0.5

# ─── Database ─────────────────────────────────────────────────────────
# [database]
# busy_timeout = "5s"

# ─── Debug ─────────────────────────────────────────────────────────────
# [debug]
# log_api_key_suffix = false               # log last 4 chars of API keys on provider calls
# compaction_debug = false                 # send compaction summary as Telegram file

# ─── HTTP ─────────────────────────────────────────────────────────────
[http]
port = 18791
bind = "127.0.0.1"
# graceful_shutdown_timeout = "30s"
# ws_enabled = false                      # enable /voice WebSocket endpoint

# ─── Logging ──────────────────────────────────────────────────────────
# [logging]
# level = "info"                          # debug, info, warn, error
# event_file = "foci.log"
# api_file = "api.jsonl"
# api_db = ""                             # SQLite API call log (default: {data_dir}/api.db, empty = disabled)
# conversation_file = ""
# full_payload = false
# payload_file = "api-payload.jsonl"
# cache_bust_detect = false
# cache_bust_idle_minutes = 10
# warning_max_per_window = 3
# warning_window_duration = "5m"
# warning_proactive_active_interval = "5m"   # min interval between proactive warning turns when user is active
# warning_proactive_inactive_interval = "1h" # min interval when user is inactive
# warning_proactive_activity_threshold = "10m" # user is "active" if last message within this window
# log_rotation = true
# rotation_period = "24h"
# retention_period = "48h"
# rotation_max_line_size = "64MB"
# archive_dir = ""                        # default: log_dir/archive/
# messages_in_log = false

# ─── TTS (text-to-speech) ─────────────────────────────────────────────
# First entry is the default. Agents override by id via tts = "id".
#
# [[tts]]
# id = "groq-playai"
# format = "openai"
# endpoint = "https://api.groq.com/openai/v1/audio/speech"
# model = "playai-tts"
# voice = "Arista-PlayAI"
# rate = 1.3                              # speed multiplier (0 = omit)
# secret = "groq.api_key"                 # secret name in secrets.toml
#
# [[tts]]
# id = "edge"
# format = "edge-tts"
# voice = "en-US-AndrewNeural"
# rate = 1.3

# ─── STT (speech-to-text) ────────────────────────────────────────────
# First entry is the default. Agents override by id via stt = "id".
#
# [[stt]]
# id = "groq-whisper"
# format = "openai"
# endpoint = "https://api.groq.com/openai/v1/audio/transcriptions"
# model = "whisper-large-v3"
# secret = "groq.api_key"                 # secret name in secrets.toml

# ─── Bitwarden ────────────────────────────────────────────────────────
# [bitwarden]
# enabled = false
# refresh_interval = "15m"
# secret_ttl = "30m"
# session_file = "/home/bitwarden/.bw_session"
# cleanup_interval = "1m"

# ─── Cache ────────────────────────────────────────────────────────────
# [cache]
# strategy = "auto"                       # auto or explicit
# ttl = "1h"                              # Anthropic prompt cache TTL: "5m" or "1h"

# ─── Usage Warnings ──────────────────────────────────────────────────
# [usage_warnings]
# name = "mana"
# thresholds = [50, 25, 10, 5]
# restore_threshold = 40                  # inject session notice when mana restores to 100% after being below this (0=disabled)

# ─── Environment ─────────────────────────────────────────────────────
# [environment]
# enabled = true
# docs_path = "shared/docs"             # path to platform docs (default: ~/shared/docs)

# ─── Tools ────────────────────────────────────────────────────────────
# [tools]
# max_result_chars = 15000
# temp_dir = "/tmp/foci-tool-results"
# tmux_cols = 300
# tmux_rows = 30
# exec_auto_background = 10
# exec_default_timeout = 30
# max_summary_chars = 300000
# auto_summarise = true
# tmux_command_timeout = "5s"
# web_fetch_timeout = "30s"
# web_fetch_max_bytes = 1048576
# web_search_timeout = "15s"
# max_concurrent_spawns = 3
# explore_max_depth = 100                # max tool loops for explore spawn mode
# tool_call_preview_chars = 450
# tmux_memory_check_interval = "5m"
# tmux_memory_warn = "10%"
# tmux_memory_critical = "20%"
# tmux_memory_kill = "30%"
# tmux_autopilot = true
# tmux_watch_threshold = "30s"
# tmux_session_ttl = "24h"
# max_upload_file_size = 52428800
# summary_context_turns = 5
# summary_context_chars = 6000
# search_provider = "brave"                  # "brave" (client-side, default) or "anthropic" (server-side, high token cost)
# fetch_provider = "builtin"                  # "builtin" (client-side, default) or "anthropic" (server-side)
# web_search_max_uses = 0                    # max searches per API call (0 = unlimited, anthropic provider only)
# web_search_allowed_domains = []            # domain whitelist (mutually exclusive with blocked)
# web_search_blocked_domains = []            # domain blacklist
# web_fetch_max_uses = 0                     # max fetches per API call (0 = unlimited, anthropic provider only)
# web_fetch_allowed_domains = []
# web_fetch_blocked_domains = []

# ─── Resources ────────────────────────────────────────────────────────
# [resources]
# memory_guard_enabled = true
# memory_guard_interval = "60s"
# memory_warn_percent = 25
# memory_kill_percent = 40
# memory_pressure_threshold = 10.0

# ─── Global Background ───────────────────────────────────────────────
# [background]
# enabled = false
# interval = "15m"
# prompt = ""

# ─── Mana ────────────────────────────────────────────────────────────
# [mana]
# invest_interval = "30m"                 # quiet period after mana reset before spending

# ─── Global Keepalive ────────────────────────────────────────────────
# [keepalive]
# enabled = false
# interval = "55m"
# prompt = ""

# ─── Global Memory Formation ─────────────────────────────────────────
# [memory_formation]
# interval_enabled = true
# interval = "1h"
# interval_prompt = ""
# consolidation_enabled = true
# consolidation_interval = "20h"
# consolidation_prompt = ""
# session_end_enabled = true
# session_end_prompt = ""

# ─── Blocked Paths ───────────────────────────────────────────────────
# Soft guardrails for write/edit tools. Returns rebuke as tool result (not error).
# Per-agent override: [[agents.blocked_paths]] replaces global.
# [[blocked_paths]]
# path = "/home/foci/myagent/code"
# rebuke = "Do not write code directly. Use claude via tmux."

# ─── Message Transforms ──────────────────────────────────────────────
# [[message_transforms]]
# find = "regex pattern"
# replace = "replacement ($1, $2, etc.)"

# ─── Custom Commands ─────────────────────────────────────────────────
# [[commands]]
# name = "deploy"
# description = "Run the deploy script"
# script = "./deploy.sh"
# timeout = 30
