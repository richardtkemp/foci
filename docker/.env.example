# Foci Docker Configuration
# Copy this file to .env and fill in the values.
#
# Required — Telegram bot credentials
FOCI_TELEGRAM_TOKEN=123456789:AAF-your-bot-token-here
FOCI_TELEGRAM_USER=your_telegram_user_id

# Authentication — how foci accesses LLM APIs
# Options: "apikey", "setup-token", "skip"
# - apikey: direct Anthropic API key (set FOCI_AUTH_TOKEN to your sk-ant-... key)
# - setup-token: uses Claude Code subscription (set FOCI_AUTH_TOKEN to the setup token)
# - skip: no auth configured (you'll need to edit foci.toml manually after setup)
FOCI_AUTH_METHOD=apikey
FOCI_AUTH_TOKEN=sk-ant-your-api-key-here

# Optional — Agent configuration
# FOCI_AGENT_ID=main
# FOCI_CHAR_MODE=defaults
