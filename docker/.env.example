# Foci Docker Configuration
# Copy this file to .env and fill in the values.
#
# At least one platform (Telegram or Discord) is required.
# You can configure both to run simultaneously.

# ── Telegram ──
# Get a bot token from @BotFather: https://t.me/BotFather
# FOCI_TELEGRAM_TOKEN=123456789:AAF-your-bot-token-here
# FOCI_TELEGRAM_USER=your_telegram_user_id

# ── Discord ──
# Create a bot at https://discord.com/developers/applications
# FOCI_DISCORD_TOKEN=NTk5MTIz.Xh4abc.your-bot-token-here
# FOCI_DISCORD_USER=your_discord_user_id

# Authentication — how foci accesses LLM APIs
# Provider: "anthropic", "gemini", "openai", "openrouter"
FOCI_PROVIDER=anthropic
FOCI_API_KEY=sk-ant-your-api-key-here

# Agent configuration
FOCI_AGENT_ID=my-agent
# FOCI_AGENT_NAME=My Agent
# FOCI_CHAR_MODE=defaults  # defaults, openclaw, import, blank

# Optional — Import directories for character and memory files
# Set these to absolute paths on the host to bake files into the image at build time.
# FOCI_CHAR_IMPORT_DIR=/path/to/character/files
# FOCI_MEMORY_IMPORT_DIR=/path/to/memory/files
